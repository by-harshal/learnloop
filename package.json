{
  "name": "learnloop",
  "version": "1.0.0",
  "description": "Turns a YouTube link, blog URL, PDF, or Google Doc/Sheet into a summary, mind map, flashcards, quiz, assignments, revision notes, and a chatbot for that topic.",
  "main": "server/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@mozilla/readability": "^0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsdom": "^29.1.1",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
